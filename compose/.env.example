# Copy to .env and fill in real values. .env must remain untracked.

# Caddy / brain vhost
BRAIN_DOMAIN=example.com
BRAIN_BEARER_TOKEN=replace-with-long-random-token

# LLM provider for Graphiti's per-write entity extraction.
# Defaults below point at OpenRouter, which gives access to every major
# model (and many local/OSS ones) from one signup. To use a different
# provider, change OPENAI_BASE_URL + OPENAI_API_KEY + GRAPHITI_MODEL_NAME:
#
#   OpenAI direct:
#     OPENAI_BASE_URL=https://api.openai.com/v1
#     GRAPHITI_MODEL_NAME=gpt-5-mini
#
#   Anthropic direct (via an OpenAI-compatible proxy like litellm, or use
#   Graphiti's native Anthropic env vars instead):
#     OPENAI_BASE_URL=http://litellm:4000
#     GRAPHITI_MODEL_NAME=claude-haiku-4-5
#
#   Local Ollama:
#     OPENAI_BASE_URL=http://host.docker.internal:11434/v1
#     OPENAI_API_KEY=ollama
#     GRAPHITI_MODEL_NAME=llama3.1:8b
#
OPENAI_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1
GRAPHITI_MODEL_NAME=anthropic/claude-haiku-4.5

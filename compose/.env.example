# Copy to .env and fill in real values. .env must remain untracked.

# ----------------------------------------------------------------------
# Caddy vhosts (VPS only; ignored when running locally)
# ----------------------------------------------------------------------
# Two hosts under this domain:
#   brain.${BRAIN_DOMAIN}      → the PWA (human capture surface; Google login)
#   brain.api.${BRAIN_DOMAIN}  → the brain API (headless; bearer)
BRAIN_DOMAIN=example.com
# Bearer for the brain API vhost (brain.api.${BRAIN_DOMAIN}). Headless consumers
# (Claude Code MCP, the inject hook, the migrator) authenticate with this.
# The PWA no longer uses it — see the PWA auth block below.
BRAIN_BEARER_TOKEN=replace-with-long-random-token

# ----------------------------------------------------------------------
# PWA auth — Google sign-in + email whitelist at the edge (oauth2-proxy)
# ----------------------------------------------------------------------
# The PWA vhost (brain.${BRAIN_DOMAIN}) is gated by oauth2-proxy: Google OIDC
# plus an email whitelist. The whitelist itself is NOT here — it's the file
# compose/oauth2-proxy-emails.txt (one address per line; copy the .example).
#
# Create the OAuth client in Google Cloud Console → Credentials →
# "OAuth client ID" → Web application. Authorized redirect URI:
#   https://brain.${BRAIN_DOMAIN}/oauth2/callback
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Signs the oauth2-proxy session cookie. Must decode to 16, 24, or 32 bytes.
# Generate:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=replace-with-openssl-rand-base64-32

# ----------------------------------------------------------------------
# Brain endpoint (used by smoke_brain.py, the migrator, and the hook)
# ----------------------------------------------------------------------
# Local dev:  BRAIN_URL=http://127.0.0.1:8000  (no bearer; leave token unset)
# VPS:        BRAIN_URL=https://brain.api.${BRAIN_DOMAIN}
BRAIN_URL=http://127.0.0.1:8000

# ----------------------------------------------------------------------
# LLM + embedder for the brain's per-write entity extraction
# ----------------------------------------------------------------------
# Default stack: Anthropic for the LLM, Voyage for the embedder. The brain
# service constructs graphiti-core directly with these (see
# brain/brain/client.py); models are tunable via BRAIN_* vars (see brain/README.md).

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# Voyage account note:
# You MUST have a payment method on file at https://dashboard.voyageai.com/
# even though typical token use fits inside the 200M-token free allowance.
# Without a card, free-tier rate limits (3 RPM) block extraction itself —
# a single capture bursts past it instantly. With a card, the free tokens apply.

# graphiti-core's default cross_encoder is OpenAI-based and demands an
# OPENAI_API_KEY at Graphiti() init time even if you never invoke reranked
# search. The placeholder below lets construction succeed; the brain's recall
# path uses RRF (no cross-encoder), so no OpenAI call is ever made. Replace
# with a real key only if you later wire cross-encoder reranking.
OPENAI_API_KEY=placeholder-unused-reranker-only

# Shell gotcha: if your terminal exports any of the above as an empty
# string (Claude Code does this for ANTHROPIC_API_KEY), Docker Compose
# will treat the empty value as authoritative and ignore this file.
# `unset ANTHROPIC_API_KEY` before `docker compose up`, or run compose
# from a subshell that doesn't inherit the var.

# ----------------------------------------------------------------------
# Graphiti namespace (single global group by default)
# ----------------------------------------------------------------------
GRAPHITI_GROUP_ID=brain

# ----------------------------------------------------------------------
# Brain service identity
# ----------------------------------------------------------------------
# The brain binds first-person language in your captures ("I", "me", "my")
# to this name, so a thought like "I want X" becomes a fact about you.
# Set it to your full name. (Single-user; multi-tenant is out of scope.)
BRAIN_USER_NAME=Your Name

# ----------------------------------------------------------------------
# Notion (used by the migrator only)
# ----------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Copy to .env and fill in real values. .env must remain untracked.

# ----------------------------------------------------------------------
# Caddy vhosts (VPS only; ignored when running locally)
# ----------------------------------------------------------------------
# Two hosts under this domain:
#   brain.${BRAIN_DOMAIN}      → the PWA (human capture surface; Google login)
#   brain.api.${BRAIN_DOMAIN}  → the brain API (headless; bearer)
BRAIN_DOMAIN=example.com
# Bearer for the brain API vhost (brain.api.${BRAIN_DOMAIN}). Headless consumers
# (Claude Code MCP, the inject hook, the migrator) authenticate with this.
# The PWA no longer uses it — see the PWA auth block below.
BRAIN_BEARER_TOKEN=replace-with-long-random-token

# ----------------------------------------------------------------------
# PWA auth — Google sign-in + email whitelist at the edge (oauth2-proxy)
# ----------------------------------------------------------------------
# The PWA vhost (brain.${BRAIN_DOMAIN}) is gated by oauth2-proxy: Google OIDC
# plus an email whitelist. The whitelist itself is NOT here — it's the file
# compose/oauth2-proxy-emails.txt (one address per line; copy the .example).
#
# Create the OAuth client in Google Cloud Console → Credentials →
# "OAuth client ID" → Web application. Authorized redirect URI:
#   https://brain.${BRAIN_DOMAIN}/oauth2/callback
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Signs the oauth2-proxy session cookie. Must decode to 16, 24, or 32 bytes.
# Generate:  openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=replace-with-openssl-rand-base64-32

# ----------------------------------------------------------------------
# Brain endpoint (used by smoke_substrate.py and the migrator)
# ----------------------------------------------------------------------
# Local dev:  BRAIN_URL=http://127.0.0.1:8100  (no bearer; leave token unset)
# VPS:        BRAIN_URL=https://brain.api.${BRAIN_DOMAIN}
BRAIN_URL=http://127.0.0.1:8100

# ----------------------------------------------------------------------
# Postgres (pgvector) — the brain's only store
# ----------------------------------------------------------------------
# The brain is a Postgres + pgvector document store (sources + chunks). The
# Postgres container is created with user `brain` / database `brain` and the
# password below. The brain service does NOT take a raw PG_DSN in .env — compose
# ASSEMBLES it from this password:
#   PG_DSN=postgresql://brain:${POSTGRES_PASSWORD}@postgres:5432/brain
# (see the `brain` service's `environment:` block in docker-compose.yml). Set
# only the password here; both the postgres and brain services read it.
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# ----------------------------------------------------------------------
# Embedder for the brain (Voyage)
# ----------------------------------------------------------------------
# The brain embeds each chunk with Voyage at ingest, and the query at recall.
# There is NO write-time LLM — ingest is split + embed + insert, no extraction.
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
# Model is optional; defaults to voyage-3-lite (512-dim, must match the
# chunks.embedding vector dim — change both together if you swap models).
# BRAIN_EMBED_MODEL=voyage-3-lite

# Voyage account note:
# You MUST have a payment method on file at https://dashboard.voyageai.com/
# even though typical token use fits inside the free allowance. Without a card,
# free-tier rate limits (3 RPM) can block a batch ingest. With a card, the free
# tokens apply.

# ----------------------------------------------------------------------
# Notion (used by /ingest and the migrator)
# ----------------------------------------------------------------------
# The integration token. Each page you ingest must be shared with this
# integration, or /ingest returns a 4xx (Notion 404 = not shared).
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx

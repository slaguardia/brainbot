# Copy to .env and fill in real values. .env must remain untracked.

# ----------------------------------------------------------------------
# Caddy / brain vhost (VPS only; ignored when running locally)
# ----------------------------------------------------------------------
BRAIN_DOMAIN=example.com
BRAIN_BEARER_TOKEN=replace-with-long-random-token

# ----------------------------------------------------------------------
# Brain endpoint (used by smoke_brain.py, the migrator, and the hook)
# ----------------------------------------------------------------------
# Local dev:  BRAIN_URL=http://127.0.0.1:8000  (no bearer; leave token unset)
# VPS:        BRAIN_URL=https://brain.${BRAIN_DOMAIN}
BRAIN_URL=http://127.0.0.1:8000

# ----------------------------------------------------------------------
# LLM + embedder for Graphiti's per-write entity extraction
# ----------------------------------------------------------------------
# Default stack: Anthropic for the LLM, Voyage for the embedder.
# Both are Anthropic-family; Voyage has a generous free tier (50M
# tokens/month). Sign up at https://www.voyageai.com if you don't have a
# key yet.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# To switch providers, edit compose/graphiti-config.yaml (llm.provider
# and/or embedder.provider) and set the matching env vars below.
#
#   OpenAI direct (single account covers both LLM and embedder):
#     # config.yaml: llm.provider: openai, embedder.provider: openai
#     OPENAI_API_KEY=sk-...
#     OPENAI_API_URL=https://api.openai.com/v1
#
#   OpenRouter (LLM only; embedder must come from elsewhere):
#     # config.yaml: llm.provider: openai (OpenAI-compatible)
#     OPENAI_API_KEY=sk-or-...
#     OPENAI_API_URL=https://openrouter.ai/api/v1
#     # plus a separate embedder, e.g. VOYAGE_API_KEY or run local Ollama
#
#   Local Ollama:
#     # config.yaml: llm.provider: openai, point api_url at the host
#     OPENAI_API_KEY=ollama
#     OPENAI_API_URL=http://host.docker.internal:11434/v1

# ----------------------------------------------------------------------
# Graphiti namespace (single global group by default)
# ----------------------------------------------------------------------
GRAPHITI_GROUP_ID=brain

# ----------------------------------------------------------------------
# Notion (used by the migrator only)
# ----------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx

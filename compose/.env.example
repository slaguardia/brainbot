# Copy to .env and fill in real values. .env must remain untracked.

# ----------------------------------------------------------------------
# Caddy / brain vhost (VPS only; ignored when running locally)
# ----------------------------------------------------------------------
BRAIN_DOMAIN=example.com
BRAIN_BEARER_TOKEN=replace-with-long-random-token

# ----------------------------------------------------------------------
# Brain endpoint (used by smoke_brain.py, the migrator, and the hook)
# ----------------------------------------------------------------------
# Local dev:  BRAIN_URL=http://127.0.0.1:8000  (no bearer; leave token unset)
# VPS:        BRAIN_URL=https://brain.${BRAIN_DOMAIN}
BRAIN_URL=http://127.0.0.1:8000

# ----------------------------------------------------------------------
# LLM for Graphiti's per-write entity extraction
# ----------------------------------------------------------------------
# Default: Anthropic Claude Haiku 4.5. One account, one key.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# To swap the LLM, edit compose/graphiti-config.yaml (llm.provider +
# llm.model) and set the matching env vars. Examples:
#
#   OpenAI direct:
#     # config.yaml: llm.provider: openai, llm.model: gpt-5-mini
#     OPENAI_API_KEY=sk-...
#     OPENAI_API_URL=https://api.openai.com/v1
#
#   OpenRouter (any model from any provider, one signup):
#     # config.yaml: llm.provider: openai, llm.model: anthropic/claude-haiku-4.5
#     OPENAI_API_KEY=sk-or-...
#     OPENAI_API_URL=https://openrouter.ai/api/v1

# ----------------------------------------------------------------------
# Embedder
# ----------------------------------------------------------------------
# Default: local Ollama running nomic-embed-text in a sibling container
# (no key, no account, fully self-hosted). The graphiti container talks
# to it at http://ollama:11434/v1 — see compose/graphiti-config.yaml.
#
# To swap the embedder to a cloud provider, edit graphiti-config.yaml
# (embedder.provider, embedder.model, embedder.dimensions). Examples:
#
#   Voyage (Anthropic's recommended embedding partner, free tier):
#     # config.yaml: embedder.provider: voyage, embedder.model: voyage-3-lite
#     VOYAGE_API_KEY=pa-...
#
#   OpenAI:
#     # config.yaml: embedder.provider: openai, embedder.model: text-embedding-3-small
#     OPENAI_API_KEY=sk-...
#     OPENAI_API_URL=https://api.openai.com/v1

# ----------------------------------------------------------------------
# Graphiti namespace (single global group by default)
# ----------------------------------------------------------------------
GRAPHITI_GROUP_ID=brain

# ----------------------------------------------------------------------
# Notion (used by the migrator only)
# ----------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Brain API. Headless consumers (Claude Code MCP, the inject hook, the
# migrator) authenticate with the bearer. The human-facing PWA lives on the
# bare brain.{$BRAIN_DOMAIN} host below.
brain.api.{$BRAIN_DOMAIN} {
    @authorized header Authorization "Bearer {$BRAIN_BEARER_TOKEN}"

    @mcp_no_slash path /mcp
    redir @mcp_no_slash /mcp/ 308

    # Points at the brain service now (not the retired graphiti MCP server).
    # The brain serves both its MCP face (/mcp, for Claude Code) and its plain
    # HTTP routes (/recall, /capture, /health) on this port.
    handle @authorized {
        reverse_proxy brain:8100
    }

    handle {
        respond 401
    }
}

# Phase 2 PWA — the human capture surface, on the bare brain.{$BRAIN_DOMAIN}
# host. Google-auth'd at the edge via oauth2-proxy (Google OIDC + email
# whitelist). The app itself is unauthenticated inside the docker network and
# only sees requests oauth2-proxy has already cleared. Replaces the old
# bearer-in-URL hack; revocation is "remove the email from
# compose/oauth2-proxy-emails.txt".
brain.{$BRAIN_DOMAIN} {
    # oauth2-proxy's own routes (/oauth2/sign_in, /callback, /auth) get their
    # OWN handle block so they bypass forward_auth. Otherwise the sign-in page
    # is itself auth-gated: it 401s, redirects to /oauth2/sign_in?rd=<sign_in>,
    # and the browser loops forever chaining rd=.
    @oauth path /oauth2/*
    handle @oauth {
        reverse_proxy oauth2-proxy:4180
    }

    # Gate everything else on a valid, whitelisted Google session. On 401,
    # bounce the user into the sign-in flow and back to where they were.
    handle {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email X-Auth-Request-User

            @bad status 401
            handle_response @bad {
                redir * /oauth2/sign_in?rd={scheme}://{host}{uri}
            }
        }

        reverse_proxy pwa:8787
    }
}

# scout — scout.{$BRAIN_DOMAIN}, Google-auth'd at the edge via oauth2-proxy.
# Same pattern as the brain PWA host: the app is unauthenticated inside brainnet
# and only ever sees requests oauth2-proxy has already cleared. No login code in
# scout. Revocation: remove the email from compose/oauth2-proxy-emails.txt.
scout.{$BRAIN_DOMAIN} {
    # /oauth2/* in its own handle block so it bypasses forward_auth (see the
    # brain vhost above for why — same sign-in redirect-loop guard).
    @oauth path /oauth2/*
    handle @oauth {
        reverse_proxy oauth2-proxy:4180
    }

    handle {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email X-Auth-Request-User

            @bad status 401
            handle_response @bad {
                redir * /oauth2/sign_in?rd={scheme}://{host}{uri}
            }
        }

        reverse_proxy scout:8765
    }
}

{
  "name": "brainbot-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "BRAIN_SERVICE_URL=http://localhost:8100 tsx watch src/server/index.ts",
    "dev": "concurrently -k -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "build": "tsc -p tsconfig.server.json && node --import tsx ./node_modules/vite/bin/vite.js build",
    "start": "node dist-server/server/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@brainbot/web-toolkit": "file:../web-toolkit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.0.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}

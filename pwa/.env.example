# Required at runtime — copy to .env and fill in real values

# Anthropic API key for the chat harness
ANTHROPIC_API_KEY=

# Postgres connection (provided by docker-compose in production)
DATABASE_URL=postgres://brainbot:brainbot@localhost:5432/personal

# Graphiti REST endpoint (phase 1 deliverable; PWA will fall back to a
# "phase-1-not-online" error if this is unset or unreachable)
GRAPHITI_URL=http://localhost:8000

# FalkorDB direct connection (for graph viz neighborhood queries)
FALKORDB_URL=redis://localhost:6379

# Bearer token shared with Caddy; required for /admin and (optionally) for
# all routes once we wire it up
PWA_BEARER_TOKEN=

# Public app domain (used to generate manifest start_url, OG tags)
APP_DOMAIN=app.localhost

# Default chat model
ANTHROPIC_MODEL=claude-sonnet-4-6

# Voice transcription (Tier 2; optional — leave unset to disable mic button)
GROQ_API_KEY=
